{
    "family": "fms-simulation",
    "containerDefinitions": [
        {
            "name": "simulation",
            "image": "919782984342.dkr.ecr.eu-central-1.amazonaws.com/simulation:latest",
            "cpu": 0,
            "memory": 512,
            "portMappings": [
                {
                    "name": "simulation-8081-tcp",
                    "containerPort": 8081,
                    "hostPort": 8081,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "SPRING_PROFILES_ACTIVE",
                    "value": "aws"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "systemControls": []
        }
    ],
    "volumes": [
        {
            "name": "logs-simulation",
            "host": {
                "sourcePath": "/var/log/containers/simulation"
            }
        }
    ],
    "requiresCompatibilities": [
        "EC2"
    ],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}