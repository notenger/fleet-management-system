{
    "family": "fms-simulation",
    "containerDefinitions": [
        {
            "name": "simulation",
            "image": "notenger/simulation:11.04.2024.12.42.08",
            "cpu": 0,
            "memory": 512,
            "portMappings": [
                {
                    "name": "simulation-8081-tcp",
                    "containerPort": 8081,
                    "hostPort": 8081,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "mountPoints": [],
            "volumesFrom": [],
            "systemControls": []
        }
    ],
    "volumes": [
        {
            "name": "logs-simulation",
            "host": {
                "sourcePath": "/var/log/containers/simulation"
            }
        }
    ],
    "requiresCompatibilities": [
        "EC2"
    ],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}