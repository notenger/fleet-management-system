{
    "family": "FMS",
    "containerDefinitions": [
        {
            "name": "vehicle-service",
            "image": "notenger/vehicle:11.04.2024.12.42.08",
            "cpu": 0,
            "memory": 512,
            "portMappings": [
                {
                    "name": "vehicle-service-8080-tcp",
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "SPRING_DATASOURCE_URL",
                    "value": "jdbc:postgresql://fleet-ms-vehicle-db.cv4mqy2smx4o.eu-central-1.rds.amazonaws.com:5432/vehicle"
                },
                {
                    "name": "CLIENTS_DEVICE_NAME",
                    "value": "10f5bdbefe1c46528a975a05029dfb43.simulation.fms-namespace"
                },
                {
                    "name": "CLIENTS_TELEMATICS_NAME",
                    "value": "c368a49732c8444d86aeb3ff7ddb4919.telematics.fms-namespace"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "systemControls": []
        }
    ],
    "volumes": [
        {
            "name": "awseb-logs-vehicle-service",
            "host": {
                "sourcePath": "/var/log/containers/vehicle-service"
            }
        }
    ],
    "requiresCompatibilities": [
        "EC2"
    ],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}