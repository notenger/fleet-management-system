{
    "family": "fms-vehicle",
    "containerDefinitions": [
        {
            "name": "vehicle",
            "image": "919782984342.dkr.ecr.eu-central-1.amazonaws.com/vehicle:04.05.2024.17.53.34",
            "cpu": 0,
            "memory": 512,
            "portMappings": [
                {
                    "name": "vehicle-8080-tcp",
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "SPRING_PROFILES_ACTIVE",
                    "value": "aws"
                },
                {
                    "name": "CLIENTS_DEVICE_URL",
                    "value": "http://172.31.23.43:8081"
                },
                {
                    "name": "CLIENTS_TELEMATICS_URL",
                    "value": "http://172.31.16.254:8082"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "systemControls": []
        }
    ],
    "volumes": [
        {
            "name": "logs-vehicle",
            "host": {
                "sourcePath": "/var/log/containers/vehicle"
            }
        }
    ],
    "requiresCompatibilities": [
        "EC2"
    ],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}